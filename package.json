{
	"name": "vite-plugin-vinext-payload",
	"version": "0.2.0",
	"description": "Vite plugin for running Payload CMS with vinext",
	"license": "MIT",
	"packageManager": "pnpm@11.5.2",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/block65/vite-plugin-vinext-payload.git"
	},
	"bugs": {
		"url": "https://github.com/block65/vite-plugin-vinext-payload/issues"
	},
	"homepage": "https://github.com/block65/vite-plugin-vinext-payload#readme",
	"keywords": [
		"vite",
		"vite-plugin",
		"vinext",
		"payload",
		"payloadcms",
		"payload-cms",
		"cloudflare",
		"cloudflare-workers",
		"d1",
		"nextjs",
		"migration",
		"rsc",
		"react-server-components",
		"cjs-interop"
	],
	"bin": {
		"vite-plugin-vinext-payload": "./dist/bin/main.js"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/src/main.d.ts",
			"default": "./dist/src/main.js"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"fmt": "oxfmt --write src bin",
		"fmt:check": "oxfmt --check src bin",
		"lint": "oxlint src bin",
		"prepare": "npm run build",
		"prepublishOnly": "npm run build",
		"preversion": "npm run lint && npm run fmt:check",
		"test": "vitest run test/init.test.ts test/server-action-fix.test.ts test/workerd-compat.test.ts test/worker-plugin-scoping.test.ts",
		"test:e2e": "vitest run test/e2e.test.ts",
		"test:e2e-d1": "vitest run test/e2e-d1.test.ts",
		"test:e2e-admin": "vitest run test/e2e-admin.test.ts",
		"test:e2e-rpc": "vitest run test/e2e-rpc-worker.test.ts",
		"test:e2e-rpc-runtime": "vitest run test/e2e-rpc-runtime.test.ts"
	},
	"dependencies": {
		"@ast-grep/napi": "^0.44.1",
		"type-fest": "^5.8.0",
		"vite-plugin-cjs-interop": "^4.0.3"
	},
	"devDependencies": {
		"@types/node": "^24.13.3",
		"oxfmt": "^0.59.0",
		"oxlint": "^1.74.0",
		"playwright": "^1.61.1",
		"typescript": "^7.0.2",
		"vite": "^8.1.5",
		"vitest": "^4.1.10"
	},
	"peerDependencies": {
		"payload": "^3.82.0",
		"vinext": "1.0.0-beta.2",
		"vite": "^8.0.0"
	},
	"peerDependenciesMeta": {
		"vinext": {
			"optional": true
		}
	},
	"engines": {
		"node": ">=24"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
