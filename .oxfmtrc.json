{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",

	"useTabs": true,
	"printWidth": 80,
	// Build output and generated files (dist, .wrangler, test/.test-project*)
	// need no entry here — .gitignore covers them and oxfmt honours it.
	// agent-standards is a git submodule: someone else's repo, checked out
	// inside this one. Formatting it would dirty its working tree.
	"ignorePatterns": ["agent-standards"],
	"sortPackageJson": {
		"sortScripts": true
	},

	"sortImports": {
		"groups": [
			"builtin",
			"external",
			"internal",
			["parent", "sibling", "index"]
		],
		"newlinesBetween": false
	},

	"overrides": [
		{
			"files": ["*.jsonc"],
			"options": {
				"trailingComma": "none"
			}
		}
	]
}
