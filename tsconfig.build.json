{
	"compilerOptions": {
		// Matches tsconfig.json — see the note there. This is the config that
		// emits to dist/, so it governs what consumers on Node >=24 receive.
		"target": "ES2024",
		"lib": ["ES2024"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": true,
		"outDir": "dist",
		"rewriteRelativeImportExtensions": true
	},
	"include": ["src", "bin"]
}
