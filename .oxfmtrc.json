{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",

	"useTabs": true,
	"printWidth": 80,
	// No ignorePatterns: everything we want skipped (dist, .wrangler, and the
	// generated files inside test/.test-project*) is already covered by
	// .gitignore, which oxfmt honours.
	"sortPackageJson": {
		"sortScripts": true
	},

	"sortImports": {
		"groups": [
			"builtin",
			"external",
			"internal",
			["parent", "sibling", "index"]
		],
		"newlinesBetween": false
	},

	"overrides": [
		{
			"files": ["*.jsonc"],
			"options": {
				"trailingComma": "none"
			}
		}
	]
}
