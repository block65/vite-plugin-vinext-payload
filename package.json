{
	"name": "vite-plugin-vinext-payload",
	"version": "0.0.6",
	"description": "Vite plugin for running Payload CMS with vinext",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/block65/vite-plugin-vinext-payload.git"
	},
	"bugs": {
		"url": "https://github.com/block65/vite-plugin-vinext-payload/issues"
	},
	"homepage": "https://github.com/block65/vite-plugin-vinext-payload#readme",
	"keywords": [
		"vite",
		"vite-plugin",
		"vinext",
		"payload",
		"payloadcms",
		"payload-cms",
		"cloudflare",
		"cloudflare-workers",
		"d1",
		"nextjs",
		"migration",
		"rsc",
		"react-server-components",
		"cjs-interop"
	],
	"bin": {
		"vite-plugin-vinext-payload": "./dist/bin/main.js"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/src/main.d.ts",
			"default": "./dist/src/main.js"
		}
	},
	"scripts": {
		"build": "tsc --project tsconfig.build.json",
		"fmt": "oxfmt --write src bin",
		"fmt:check": "oxfmt --check src bin",
		"lint": "oxlint src bin",
		"prepublishOnly": "npm run build",
		"preversion": "npm run lint && npm run fmt:check",
		"test": "node --test test/init.test.ts",
		"test:e2e": "node --test test/e2e.test.ts",
		"test:e2e-d1": "node --test test/e2e-d1.test.ts"
	},
	"dependencies": {
		"@ast-grep/napi": "^0.42.0",
		"type-fest": "^5.5.0",
		"vite-plugin-cjs-interop": "^2.4.4"
	},
	"devDependencies": {
		"@types/node": "^24.12.0",
		"oxfmt": "^0.41.0",
		"oxlint": "^1.56.0",
		"typescript": "^6.0.1-rc",
		"vite": "^8.0.1"
	},
	"peerDependencies": {
		"vite": "^6.0.0 || ^7.0.0 || ^8.0.0"
	},
	"engines": {
		"node": ">=24"
	},
	"publishConfig": {
		"access": "public",
		"provenance": true
	}
}
